# Mawutor Dezor Enterprise - Environment Variables
# Copy to .env and fill in production values

PORT=3000
JWT_SECRET=change-this-to-a-long-random-string-in-production-32+chars
# Example: generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# For years of permanent storage (RECOMMENDED):
# Create free Atlas cluster at https://cloud.mongodb.com
# Get your connection string:
MONGODB_URI=mongodb+srv://mawutor_admin:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/mawutor-dezor?retryWrites=true&w=majority
MONGODB_DB=mawutor-dezor

# If MONGODB_URI is NOT set, app uses file JSON (ephemeral, for quick testing)
# If MONGODB_URI IS set, app uses MongoDB Atlas (permanent for years)
